<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.powerops.mapper.UserMapper">

    <resultMap id="SysUserResultMap" type="com.example.powerops.entity.SysUser">
        <id column="USER_ID" property="userId"/>
        <result column="USERNAME" property="username"/>
        <result column="PASSWORD" property="password"/>
        <result column="REAL_NAME" property="realName"/>
        <result column="PHONE" property="phone"/>
        <result column="ROLE_CODE" property="roleCode"/>
        <result column="STATUS" property="status"/>
        <result column="CREATE_TIME" property="createTime"/>
    </resultMap>

    <!-- 根据用户名查询 -->
    <select id="findByUsername" resultMap="SysUserResultMap">
        SELECT * FROM SYS_USER WHERE USERNAME = #{username}
    </select>

    <!-- 根据ID查询 -->
    <select id="findById" resultMap="SysUserResultMap">
        SELECT * FROM SYS_USER WHERE USER_ID = #{userId}
    </select>

    <!-- 分页查询用户列表 -->
    <select id="listUsers" resultMap="SysUserResultMap">
        SELECT * FROM (
            SELECT t.*, ROWNUM rn FROM (
                SELECT * FROM SYS_USER
                <where>
                    <if test="username != null and username != ''">
                        AND USERNAME LIKE '%' || #{username} || '%'
                    </if>
                    <if test="roleCode != null and roleCode != ''">
                        AND ROLE_CODE = #{roleCode}
                    </if>
                    <if test="status != null">
                        AND STATUS = #{status}
                    </if>
                </where>
                ORDER BY CREATE_TIME DESC
            ) t WHERE ROWNUM &lt;= #{offset} + #{limit}
        ) WHERE rn &gt; #{offset}
    </select>

    <!-- 查询总数 -->
    <select id="countUsers" resultType="long">
        SELECT COUNT(*) FROM SYS_USER
        <where>
            <if test="username != null and username != ''">
                AND USERNAME LIKE '%' || #{username} || '%'
            </if>
            <if test="roleCode != null and roleCode != ''">
                AND ROLE_CODE = #{roleCode}
            </if>
            <if test="status != null">
                AND STATUS = #{status}
            </if>
        </where>
    </select>

    <!-- 新增用户 -->
    <insert id="insert" parameterType="com.example.powerops.entity.SysUser">
        INSERT INTO SYS_USER (
            USER_ID, USERNAME, PASSWORD, REAL_NAME, PHONE, ROLE_CODE, STATUS, CREATE_TIME
        ) VALUES (
            SEQ_SYS_USER.NEXTVAL, #{username}, #{password}, #{realName}, #{phone}, #{roleCode}, #{status}, SYSDATE
        )
    </insert>

    <!-- 更新用户 -->
    <update id="update" parameterType="com.example.powerops.entity.SysUser">
        UPDATE SYS_USER SET
            USERNAME = #{username},
            PASSWORD = #{password},
            REAL_NAME = #{realName},
            PHONE = #{phone},
            ROLE_CODE = #{roleCode},
            STATUS = #{status}
        WHERE USER_ID = #{userId}
    </update>

    <!-- 删除用户 -->
    <delete id="deleteById">
        DELETE FROM SYS_USER WHERE USER_ID = #{userId}
    </delete>

</mapper>
